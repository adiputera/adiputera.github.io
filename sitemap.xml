---
layout: null
---
{%- assign lm = site.data.lastmod -%}
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:xhtml="http://www.w3.org/1999/xhtml"
        xmlns:image="http://www.google.com/schemas/sitemap-image/1.1">

    <!-- Main resume pages (English and Indonesian) -->
    <url>
        <loc>{{ site.url }}/</loc>
        <xhtml:link rel="alternate" hreflang="en" href="{{ site.url }}/" />
        <xhtml:link rel="alternate" hreflang="id" href="{{ site.url }}/id" />
        <xhtml:link rel="alternate" hreflang="x-default" href="{{ site.url }}/" />
        <lastmod>{{ lm.home_en }}</lastmod>
        <changefreq>monthly</changefreq>
        <priority>1.0</priority>
        <image:image>
            <image:loc>{{ site.url }}/images/photo.webp</image:loc>
            <image:title>Yusuf Adiputera - Lead Software Engineer</image:title>
            <image:caption>Professional photo of Yusuf Adiputera, Lead Software Engineer specializing in Java and SAP Commerce</image:caption>
        </image:image>
    </url>

    <url>
        <loc>{{ site.url }}/id</loc>
        <xhtml:link rel="alternate" hreflang="en" href="{{ site.url }}/" />
        <xhtml:link rel="alternate" hreflang="id" href="{{ site.url }}/id" />
        <xhtml:link rel="alternate" hreflang="x-default" href="{{ site.url }}/" />
        <lastmod>{{ lm.home_id }}</lastmod>
        <changefreq>monthly</changefreq>
        <priority>1.0</priority>
        <image:image>
            <image:loc>{{ site.url }}/images/photo.webp</image:loc>
            <image:title>Yusuf Adiputera - Lead Software Engineer</image:title>
            <image:caption>Professional photo of Yusuf Adiputera, Lead Software Engineer specializing in Java and SAP Commerce</image:caption>
        </image:image>
    </url>

    <!-- Skills pages -->
    <url>
        <loc>{{ site.url }}/skills</loc>
        <xhtml:link rel="alternate" hreflang="en" href="{{ site.url }}/skills" />
        <xhtml:link rel="alternate" hreflang="id" href="{{ site.url }}/skills-id" />
        <xhtml:link rel="alternate" hreflang="x-default" href="{{ site.url }}/skills" />
        <lastmod>{{ lm.skills_en }}</lastmod>
        <changefreq>monthly</changefreq>
        <priority>0.9</priority>
    </url>

    <url>
        <loc>{{ site.url }}/skills-id</loc>
        <xhtml:link rel="alternate" hreflang="en" href="{{ site.url }}/skills" />
        <xhtml:link rel="alternate" hreflang="id" href="{{ site.url }}/skills-id" />
        <xhtml:link rel="alternate" hreflang="x-default" href="{{ site.url }}/skills" />
        <lastmod>{{ lm.skills_id }}</lastmod>
        <changefreq>monthly</changefreq>
        <priority>0.9</priority>
    </url>

    <!-- FAQ pages -->
    <url>
        <loc>{{ site.url }}/faq</loc>
        <xhtml:link rel="alternate" hreflang="en" href="{{ site.url }}/faq" />
        <xhtml:link rel="alternate" hreflang="id" href="{{ site.url }}/faq-id" />
        <xhtml:link rel="alternate" hreflang="x-default" href="{{ site.url }}/faq" />
        <lastmod>{{ lm.faq_en }}</lastmod>
        <changefreq>monthly</changefreq>
        <priority>0.8</priority>
    </url>

    <url>
        <loc>{{ site.url }}/faq-id</loc>
        <xhtml:link rel="alternate" hreflang="en" href="{{ site.url }}/faq" />
        <xhtml:link rel="alternate" hreflang="id" href="{{ site.url }}/faq-id" />
        <xhtml:link rel="alternate" hreflang="x-default" href="{{ site.url }}/faq" />
        <lastmod>{{ lm.faq_id }}</lastmod>
        <changefreq>monthly</changefreq>
        <priority>0.8</priority>
    </url>

    <!-- Full version pages -->
    <url>
        <loc>{{ site.url }}/full</loc>
        <xhtml:link rel="alternate" hreflang="en" href="{{ site.url }}/full" />
        <xhtml:link rel="alternate" hreflang="id" href="{{ site.url }}/full-id" />
        <xhtml:link rel="alternate" hreflang="x-default" href="{{ site.url }}/full" />
        <lastmod>{{ lm.full_en }}</lastmod>
        <changefreq>monthly</changefreq>
        <priority>0.8</priority>
    </url>

    <url>
        <loc>{{ site.url }}/full-id</loc>
        <xhtml:link rel="alternate" hreflang="en" href="{{ site.url }}/full" />
        <xhtml:link rel="alternate" hreflang="id" href="{{ site.url }}/full-id" />
        <xhtml:link rel="alternate" hreflang="x-default" href="{{ site.url }}/full" />
        <lastmod>{{ lm.full_id }}</lastmod>
        <changefreq>monthly</changefreq>
        <priority>0.8</priority>
    </url>

    <!-- Articles index (page 1 + any paginated pages from jekyll-paginate-v2) -->
    {%- assign per_page = site.pagination.per_page | default: 6 -%}
    {%- assign article_count = site.articles | size -%}
    {%- assign total_pages = article_count | divided_by: per_page -%}
    {%- assign remainder = article_count | modulo: per_page -%}
    {%- if remainder > 0 -%}{%- assign total_pages = total_pages | plus: 1 -%}{%- endif -%}
    {%- for i in (1..total_pages) %}
    <url>
        <loc>{{ site.url }}/articles/{% if i > 1 %}page{{ i }}/{% endif %}</loc>
        <lastmod>{{ lm.articles | default: site.time | date: "%Y-%m-%d" }}</lastmod>
        <changefreq>monthly</changefreq>
        <priority>{% if i == 1 %}0.8{% else %}0.6{% endif %}</priority>
    </url>
    {% endfor %}

    <!-- Articles collection - dynamically generated -->
    {%- for article in site.articles -%}
    <url>
        <loc>{{ site.url }}{{ article.url }}</loc>
        <lastmod>{{ article.date_modified | default: article.date | date: "%Y-%m-%d" }}</lastmod>
        <changefreq>monthly</changefreq>
        <priority>0.7</priority>
    </url>
    {%- endfor -%}

    <!-- Case studies index (page 1 + any paginated pages) -->
    {%- assign cs_articles = site.articles | where: "category", "case-study" -%}
    {%- assign cs_count = cs_articles | size -%}
    {%- assign cs_total_pages = cs_count | divided_by: per_page -%}
    {%- assign cs_remainder = cs_count | modulo: per_page -%}
    {%- if cs_remainder > 0 -%}{%- assign cs_total_pages = cs_total_pages | plus: 1 -%}{%- endif -%}
    {%- for i in (1..cs_total_pages) %}
    <url>
        <loc>{{ site.url }}/case-studies/{% if i > 1 %}page{{ i }}/{% endif %}</loc>
        <lastmod>{{ lm.case_studies | default: site.time | date: "%Y-%m-%d" }}</lastmod>
        <changefreq>monthly</changefreq>
        <priority>{% if i == 1 %}0.8{% else %}0.6{% endif %}</priority>
    </url>
    {% endfor %}

    <!-- Tags index -->
    {%- assign all_tags = "" | split: "" -%}
    {%- for article in site.articles -%}
        {%- for tag in article.tags -%}
            {%- unless all_tags contains tag -%}
                {%- assign all_tags = all_tags | push: tag -%}
            {%- endunless -%}
        {%- endfor -%}
    {%- endfor -%}
    {%- if all_tags.size > 0 %}
    <url>
        <loc>{{ site.url }}/tags/</loc>
        <lastmod>{{ site.time | date: "%Y-%m-%d" }}</lastmod>
        <changefreq>monthly</changefreq>
        <priority>0.6</priority>
    </url>
    {%- endif -%}

    <!-- Tag index pages - one per unique tag across all articles -->
    {%- for tag in all_tags -%}
    <url>
        <loc>{{ site.url }}/tags/{{ tag | slugify }}/</loc>
        <lastmod>{{ site.time | date: "%Y-%m-%d" }}</lastmod>
        <changefreq>monthly</changefreq>
        <priority>0.5</priority>
    </url>
    {%- endfor -%}

</urlset>
